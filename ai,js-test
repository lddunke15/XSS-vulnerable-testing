export async function analyzeLog(log) {
  const url = "http://sushi.it.ilstu.edu:8080/ollama/v1/chat/completions";

  const payload = {
    model: "translategemma:latest",
    messages: [
      {
        role: "user",
        content: `
You are a cybersecurity analyzer.

Classify this request:
- Type (XSS, SQLi, Normal, Unknown)
- Severity (low, medium, high)
- Explanation
- Fix suggestion

LOG:
${JSON.stringify(log)}
`
      }
    ],
    stream: false
  };

  try {
    const res = await fetch(url, {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify(payload)
    });

    // 🔥 STEP 1: get raw text first (NOT json yet)
    const text = await res.text();

    console.log("🧠 RAW AI RESPONSE TEXT:", text);

    let data;
    try {
      data = JSON.parse(text);
    } catch (e) {
      console.log("❌ NOT JSON RESPONSE");
      return "AI returned non-JSON response:\n" + text;
    }

    console.log("🧠 PARSED AI RESPONSE:", data);

    // 🔥 STEP 2: try ALL known formats
    const output =
      data?.choices?.[0]?.message?.content ||
      data?.message?.content ||
      data?.response ||
      data?.output ||
      data?.text;

    // 🔥 STEP 3: HARD FALLBACK (this prevents undefined forever)
    if (!output) {
      return (
        "⚠️ Could not extract AI output.\n\nRAW:\n" +
        JSON.stringify(data, null, 2)
      );
    }

    return output;

  } catch (err) {
    console.log("❌ AI REQUEST FAILED:", err);
    return "AI request failed: " + err.message;
  }
}
